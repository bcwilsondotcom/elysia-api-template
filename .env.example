# Environment
DATABASE_URL=
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
COOKIE_DOMAIN=localhost

# Optional
LOG_LEVEL=debug
PORT=3000
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Set to 1 when running behind a trusted proxy (e.g. Vercel, Cloudflare) that
# overwrites x-forwarded-for with the real client IP. When unset, the TCP-layer
# address is used as the rate-limit key instead.
# TRUST_PROXY=1

# OpenTelemetry (optional — set to export traces)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=my-api

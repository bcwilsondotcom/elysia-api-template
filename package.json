{
  "name": "elysia-api-template",
  "version": "1.0.0",
  "description": "Production-ready Elysia + Bun API template with Drizzle, BetterAuth, Stripe, and OpenAPI Type Gen",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "start": "NODE_ENV=production bun run src/server.ts",
    "typecheck": "bun x tsc --noEmit",
    "lint": "bun x biome check src/ tests/",
    "lint:fix": "bun x biome check --write src/ tests/",
    "test": "bun test",
    "db:generate": "bun x drizzle-kit generate",
    "db:migrate": "bun x drizzle-kit migrate",
    "db:push": "bun x drizzle-kit push",
    "db:studio": "bun x drizzle-kit studio",
    "test:load": "k6 run tests/load/smoke.js"
  },
  "overrides": {
    "@sinclair/typebox": "0.34.49"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/bun": "1.3.11",
    "@types/k6": "1.7.0",
    "drizzle-kit": "0.31.10",
    "pino-pretty": "13.1.3"
  },
  "peerDependencies": {
    "typescript": ">=5"
  },
  "dependencies": {
    "@elysiajs/cors": "1.4.1",
    "@elysiajs/openapi": "1.4.14",
    "@elysiajs/opentelemetry": "1.4.11",
    "@elysiajs/server-timing": "1.4.0",
    "@neondatabase/serverless": "1.0.2",
    "better-auth": "1.5.6",
    "drizzle-orm": "0.45.2",
    "drizzle-typebox": "0.3.3",
    "elysia": "1.4.28",
    "elysia-rate-limit": "4.5.1",
    "pino": "10.3.1",

    "stripe": "22.0.0",
    "ulid": "3.0.2"
  }
}